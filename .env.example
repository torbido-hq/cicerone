# --- scheduling & tuning ------------------------------------------------------

# 5-field cron expression, evaluated in UTC
CRON_SCHEDULE=0 3 * * *

TOP_K=10
INTERACTION_HALF_LIFE_DAYS=90
FEATURE_CONFIG_PATH=/app/config/features.yml

# --- input --------------------------------------------------------------------
# INPUT_KIND: "dataset" (static parquet files) or "db" (read from Postgres)

INPUT_KIND=dataset

# INPUT_KIND=dataset options:
# INPUT_STORAGE_BACKEND: "s3" (S3-compatible object storage, e.g. Cloudflare
# R2) or "local" (a mounted directory containing events.parquet and,
# optionally, users.parquet/items.parquet).
INPUT_STORAGE_BACKEND=s3
INPUT_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
INPUT_S3_ACCESS_KEY_ID=changeme
INPUT_S3_SECRET_ACCESS_KEY=changeme
INPUT_S3_BUCKET=torbido-recsys
INPUT_S3_PREFIX=datasets/latest
# INPUT_LOCAL_PATH=/data/input

# INPUT_KIND=db options (Postgres via SQLAlchemy):
# INPUT_DATABASE_URL=postgresql+psycopg://user:password@host:5432/torbido
# INPUT_EVENTS_TABLE=events
# INPUT_USERS_TABLE=users
# INPUT_ITEMS_TABLE=items
# Optional raw SQL overrides, e.g. to join torbido's own schema instead of
# requiring it to materialize events/users/items tables verbatim:
# INPUT_EVENTS_QUERY=SELECT ... FROM analytics_events ...
# INPUT_USERS_QUERY=SELECT ... FROM users ...
# INPUT_ITEMS_QUERY=SELECT ... FROM products ...

# --- output -------------------------------------------------------------------
# OUTPUT_KIND: "dataset" (static parquet files) or "db" (write into Postgres)

OUTPUT_KIND=dataset

# OUTPUT_KIND=dataset options (same backends as input):
OUTPUT_STORAGE_BACKEND=s3
OUTPUT_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
OUTPUT_S3_ACCESS_KEY_ID=changeme
OUTPUT_S3_SECRET_ACCESS_KEY=changeme
OUTPUT_S3_BUCKET=torbido-recsys
OUTPUT_S3_PREFIX=recommendations/latest
# OUTPUT_LOCAL_PATH=/data/output

# OUTPUT_KIND=db options:
# OUTPUT_DATABASE_URL=postgresql+psycopg://user:password@host:5432/torbido
# OUTPUT_RECOMMENDATIONS_TABLE=recommendations
# OUTPUT_MANIFEST_TABLE=recommendation_runs
