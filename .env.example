# Cicerone reads its structural configuration from config/cicerone.toml
# (kind of backend, bucket/table names, scheduling, tuning...). This file
# only supplies the secrets that cicerone.toml references via ${...}
# placeholders — see config/cicerone.toml for the full list of options and
# how to switch backends (S3-compatible storage, local disk, or a database).

# Used when [input.options].storage_backend = "s3" in cicerone.toml
INPUT_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
INPUT_S3_ACCESS_KEY_ID=changeme
INPUT_S3_SECRET_ACCESS_KEY=changeme
INPUT_S3_BUCKET=my-recsys-bucket

# Used when [output.options].storage_backend = "s3" in cicerone.toml
OUTPUT_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
OUTPUT_S3_ACCESS_KEY_ID=changeme
OUTPUT_S3_SECRET_ACCESS_KEY=changeme
OUTPUT_S3_BUCKET=my-recsys-bucket

# Used when [input]/[output].kind = "db" in cicerone.toml instead
# INPUT_DATABASE_URL=postgresql+psycopg://user:password@host:5432/mydb
# OUTPUT_DATABASE_URL=postgresql+psycopg://user:password@host:5432/mydb

